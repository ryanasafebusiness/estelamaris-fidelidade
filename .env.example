# =============================================================================
# Estelamaris — variáveis de ambiente (MODELO)
# -----------------------------------------------------------------------------
# Copie este arquivo para `.env.local` e preencha com os valores reais.
# `.env.local` está no .gitignore e NUNCA deve ser commitado.
# NUNCA coloque a SERVICE ROLE KEY em variáveis NEXT_PUBLIC_*.
# =============================================================================

# --- Supabase: PÚBLICO (vai para o browser) ----------------------------------
# Seguro expor. Sujeito a RLS.
NEXT_PUBLIC_SUPABASE_URL=
# Anon key (JWT legado) OU publishable key (sb_publishable_...). Qualquer uma serve.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase: SEGREDO (apenas servidor / n8n) -------------------------------
# service_role ignora RLS. Só em rotas de servidor e no n8n. NUNCA no client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (usada pelo n8n, que lê o valor da nota) ----------------------
# A chamada à API da Anthropic é feita pelo n8n. Mantida aqui por completude.
ANTHROPIC_API_KEY=

# --- Integração App <-> n8n --------------------------------------------------
# URL do webhook do n8n que o app chama para processar uma nota enviada.
N8N_WEBHOOK_URL=
# Segredo compartilhado para autenticar chamadas entre o app e o n8n
# (header/HMAC), nos dois sentidos. Gere um valor aleatório forte.
N8N_WEBHOOK_SECRET=

# --- App ---------------------------------------------------------------------
# URL pública do app (usada em callbacks/links). Ex.: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
