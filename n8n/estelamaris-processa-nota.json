    {
      "id": "353543da-7224-46f9-9d15-d09d5f37a310",
      "name": "Monta mensagem IA",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, 400],
      "parameters": { "mode": "runOnceForAllItems", "language": "javaScript", "jsCode": "const buffer = await this.helpers.getBinaryDataBuffer(0, 'data');\nconst b64 = buffer.toString('base64');\nconst bin = $input.first().binary.data;\nconst mime = (bin && bin.mimeType) ? bin.mimeType : 'image/jpeg';\nconst prompt = 'Voce e um extrator de dados de cupons fiscais brasileiros (NFC-e/SAT). Analise a imagem e responda APENAS com um objeto JSON valido, sem texto extra e sem cercas de codigo. Campos: eh_cupom_fiscal (boolean), valor_total (number ou null), data_compra no formato YYYY-MM-DD ou null, estabelecimento (string ou null), cnpj (string ou null), chave_acesso (44 digitos ou null), confianca (number 0 a 1). Regras: se NAO for cupom/nota fiscal retorne eh_cupom_fiscal=false e os demais null; valor_total e o TOTAL pago (procure TOTAL, VALOR A PAGAR, VALOR PAGO) e ignore subtotais, troco e itens; use ponto como separador decimal e nao inclua simbolo de moeda; responda somente o JSON.';\nreturn [{ json: { messages: [ { role: 'user', content: [ { type: 'text', text: prompt }, { type: 'image_url', image_url: { url: 'data:' + mime + ';base64,' + b64 } } ] } ] } }];" },
      "onError": "continueErrorOutput"
    },
    {
      "id": "cf0c759e-98f3-4c9e-b572-9730aaf37dce",
      "name": "Groq - extrai valor",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1680, 400],
      "parameters": { "method": "POST", "url": "https://api.groq.com/openai/v1/chat/completions", "authentication": "predefinedCredentialType", "nodeCredentialType": "groqApi", "sendBody": true, "contentType": "json", "specifyBody": "json", "jsonBody": "={{ { \"model\": $(\"Prepara dados\").item.json.modelo_ia, \"messages\": $json.messages, \"max_tokens\": 800, \"temperature\": 0, \"reasoning_effort\": \"none\" } }}", "options": {} },
      "onError": "continueErrorOutput"
    },
    {
      "id": "9f83f8a6-aa3f-47b2-9ec8-d88854fbd90a",
      "name": "Parse + validacoes",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1920, 400],
      "parameters": { "mode": "runOnceForAllItems", "language": "javaScript", "jsCode": "const raw = $input.first().json;\nlet text = '';\ntry { text = raw.choices[0].message.content || ''; } catch (err) { text = ''; }\nlet clean = String(text).trim();\nclean = clean.replace(/<think>[\\s\\S]*?<\\/think>/gi, '').trim();\nconst s = clean.indexOf('{'); const e2 = clean.lastIndexOf('}');\nif (s >= 0 && e2 > s) { clean = clean.slice(s, e2 + 1); }\nlet data = {}; let parseOk = true;\ntry { data = JSON.parse(clean); } catch (err) { parseOk = false; }\nconst cfg = $('Prepara dados').first().json;\nconst janela = Number(cfg.janela_dias) || 90;\nconst verificarFarmacia = cfg.verificar_farmacia === true || cfg.verificar_farmacia === 'true';\nconst cnpjFarm = String(cfg.cnpj_farmacia || '').replace(/\\D/g, '');\nconst nomeFarm = String(cfg.nome_farmacia || '').toUpperCase().normalize('NFD').replace(/[̀-ͯ]/g, '');\nlet valido = true; let motivo = '';\nconst ehCupom = parseOk && data.eh_cupom_fiscal === true;\nconst valor = Number(data.valor_total);\nconst dataCompra = data.data_compra || null;\nconst estab = data.estabelecimento || null;\nconst cnpjDigits = String(data.cnpj || '').replace(/\\D/g, '');\nconst chave = data.chave_acesso ? String(data.chave_acesso).replace(/\\D/g, '') : '';\nif (!parseOk) { valido = false; motivo = 'nao consegui ler a nota'; }\nelse if (!ehCupom) { valido = false; motivo = 'imagem nao parece um cupom fiscal'; }\nelse if (!(valor > 0)) { valido = false; motivo = 'valor da nota ilegivel ou zerado'; }\nelse {\n  if (dataCompra) {\n    const d = new Date(dataCompra + 'T00:00:00Z');\n    const diff = (Date.now() - d.getTime()) / 86400000;\n    if (isFinite(diff) && diff > janela) { valido = false; motivo = 'nota fora do prazo de ' + janela + ' dias'; }\n    else if (isFinite(diff) && diff < -1) { valido = false; motivo = 'data da nota invalida'; }\n  }\n  if (valido && verificarFarmacia && (cnpjFarm || nomeFarm)) {\n    const estabNorm = String(estab || '').toUpperCase().normalize('NFD').replace(/[̀-ͯ]/g, '');\n    const cnpjBate = cnpjFarm && cnpjDigits && cnpjDigits === cnpjFarm;\n    const nomeBate = nomeFarm && estabNorm.includes(nomeFarm);\n    if (!cnpjBate && !nomeBate) { valido = false; motivo = 'nota nao e da Estelamaris'; }\n  }\n}\nlet hash;\nif (chave && chave.length >= 20) { hash = 'chave:' + chave; }\nelse { hash = 'dados:' + cnpjDigits + '|' + (isFinite(valor) ? valor.toFixed(2) : '0') + '|' + (dataCompra || ''); }\nreturn [{ json: { valido: valido, motivo: motivo, valor_total: isFinite(valor) ? valor : null, data_compra: dataCompra, estabelecimento: estab, cnpj: cnpjDigits || null, chave_acesso: chave || null, hash_dedupe: hash, ai_raw: parseOk ? data : { erro: 'parse_failed', texto: text } } }];" },
      "onError": "continueErrorOutput"
    },
    {
      "id": "345e8d7d-92c5-449d-9c83-436f6ec63d3e",
      "name": "Nota valida?",
