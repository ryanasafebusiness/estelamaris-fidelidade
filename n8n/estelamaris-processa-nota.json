      "name": "Rejeita (erro geral)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [2160, 700],
      "parameters": { "method": "POST", "url": "={{ $(\"Prepara dados\").item.json.supabase_url }}/rest/v1/rpc/reject_receipt", "authentication": "predefinedCredentialType", "nodeCredentialType": "supabaseApi", "sendBody": true, "contentType": "json", "specifyBody": "json", "jsonBody": "={{ { \"p_receipt\": $(\"Prepara dados\").item.json.receipt_id, \"p_motivo\": \"erro ao processar a nota\" } }}", "options": { "response": { "response": { "neverError": true } } } }
